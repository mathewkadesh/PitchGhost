# Optional. Base URL of the deployed Cloudflare Worker that powers live
# research for firms without a sample dossier (see worker/README.md). If
# unset, researching a non-sample firm shows a friendly "not configured yet"
# message — the sample dossiers and directory work without it.
#
# Example: VITE_GHOST_API_URL=https://pitchghost-ghost.your-subdomain.workers.dev
VITE_GHOST_API_URL=
